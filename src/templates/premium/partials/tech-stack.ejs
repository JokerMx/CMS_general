<section id="tech-stack" style="padding: 80px 20px; max-width: 1200px; margin: 0 auto;">
  <div style="text-align: center; margin-bottom: 60px;">
    <span style="display: inline-block; background: var(--badge-bg); color: var(--accent); padding: 8px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 600; margin-bottom: 15px;">
      TECNOLOGÍAS
    </span>
    <h2 style="font-size: 2.5rem; margin-bottom: 15px;">Nuestro <span style="background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Stack</span></h2>
    <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Trabajamos con las tecnologías más demandadas y modernas del mercado.</p>
  </div>
  
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px;">
    <% if (typeof techStack !== 'undefined' && techStack.length > 0) { %>
      <% techStack.forEach((tech, index) => { %>
        <div class="fade-in" style="animation-delay: <%= (index * 0.1) %>s; background: var(--card-bg); border-radius: 16px; padding: 25px; box-shadow: var(--card-shadow); border: 1px solid var(--border);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <span style="font-weight: 600; color: var(--text);"><%= tech.name %></span>
            <span style="color: var(--accent); font-weight: 700;"><%= tech.level %>%</span>
          </div>
          <div style="background: var(--badge-bg); border-radius: 10px; height: 8px; overflow: hidden;">
            <div style="background: var(--gradient); height: 100%; width: <%= tech.level %>%; border-radius: 10px; transition: width 1s ease;"></div>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>
</section>
<section id="portfolio" style="padding: 80px 20px; background: var(--premium-bg2, #1a0a1e);">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 60px;">
      <span class="premium-badge" style="margin-bottom: 15px;">
        PORTAFOLIO
      </span>
      <h2 style="font-size: 2.5rem; color: var(--premium-text); margin-bottom: 15px;">Proyectos <span class="premium-gradient-text">destacados</span></h2>
      <p style="color: var(--premium-text-secondary); max-width: 600px; margin: 0 auto;">Conoce algunos de nuestros proyectos. Datos obtenidos directamente desde GitHub.</p>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px;">
      <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
        <% projects.forEach((project, index) => { %>
          <div class="fade-in premium-card" style="animation-delay: <%= (index * 0.1) %>s; display: flex; flex-direction: column;">
            
            <!-- Cabecera del proyecto -->
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
              <span style="font-size: 1.5rem;"><%= project.isPrivate ? '🔒' : '📁' %></span>
              <h3 style="font-size: 1.2rem; color: var(--premium-text);"><%= project.name %></h3>
            </div>
            
            <!-- Descripción -->
            <p style="color: var(--premium-text-secondary); margin-bottom: 20px; flex-grow: 1; line-height: 1.6;">
              <%= project.description.substring(0, 120) %><%= project.description.length > 120 ? '...' : '' %>
            </p>
            
            <!-- Badges de tecnologías -->
            <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px;">
              <% if (project.techBadges && project.techBadges.length > 0) { %>
                <% project.techBadges.slice(0, 4).forEach(badge => { %>
                  <span style="background: <%= badge.color %>20; color: <%= badge.color %>; padding: 5px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; border: 1px solid <%= badge.color %>50;">
                    <%= badge.name %>
                  </span>
                <% }); %>
                <% if (project.techBadges.length > 4) { %>
                  <span class="premium-badge">+<%= project.techBadges.length - 4 %></span>
                <% } %>
              <% } %>
            </div>
            
            <!-- Stats -->
            <div style="display: flex; gap: 20px; margin-bottom: 20px; color: var(--premium-text-secondary); font-size: 0.9rem;">
              <span>⭐ <%= project.stars %></span>
              <span>🔀 <%= project.forks %></span>
            </div>
            
            <!-- Botón -->
            <a href="<%= project.url %>" target="_blank" class="premium-btn-primary" style="text-align: center; padding: 12px 20px; font-size: 0.95rem;">
              Ver en GitHub →
            </a>
          </div>
        <% }); %>
      <% } else { %>
        <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--premium-text-secondary);">
          <p>No se encontraron proyectos.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>
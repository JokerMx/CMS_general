<div style="text-align: center; margin-bottom: 50px;">
  <h1 style="font-size: 3.5rem; color: var(--premium-accent); text-shadow: 0 0 20px rgba(210,54,105,0.4); margin-bottom: 10px; letter-spacing: -1px;">
    <%= title %>
  </h1>
  <p style="font-size: 1.3rem;">Bienvenido, <strong style="color: var(--premium-accent);"><%= user.name %></strong>. Estás en la zona VIP.</p>
</div>

<div style="display: flex; flex-wrap: wrap; gap: 30px; justify-content: center;">
  <div style="background: var(--premium-card-bg); backdrop-filter: blur(10px); border-radius: 24px; padding: 35px 30px; width: 280px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.4); transition: all 0.4s;"
       onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 20px 50px rgba(210,54,105,0.3)'"
       onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 10px 40px rgba(0,0,0,0.1)'">
    <div style="font-size: 3rem; margin-bottom: 20px;">💎</div>
    <h3 style="color: var(--premium-accent);">Soporte VIP</h3>
    <p style="color: var(--premium-text);">Atención prioritaria 24/7 con respuesta en menos de 1 hora.</p>
  </div>
  <div style="background: var(--premium-card-bg); backdrop-filter: blur(10px); border-radius: 24px; padding: 35px 30px; width: 280px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.4); transition: all 0.4s;"
       onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 20px 50px rgba(210,54,105,0.3)'"
       onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 10px 40px rgba(0,0,0,0.1)'">
    <div style="font-size: 3rem; margin-bottom: 20px;">🎁</div>
    <h3 style="color: var(--premium-accent);">Beneficios Exclusivos</h3>
    <p style="color: var(--premium-text);">Descuentos especiales y acceso anticipado a nuevas funciones.</p>
  </div>
  <div style="background: var(--premium-card-bg); backdrop-filter: blur(10px); border-radius: 24px; padding: 35px 30px; width: 280px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.4); transition: all 0.4s;"
       onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 20px 50px rgba(210,54,105,0.3)'"
       onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 10px 40px rgba(0,0,0,0.1)'">
    <div style="font-size: 3rem; margin-bottom: 20px;">⚙️</div>
    <h3 style="color: var(--premium-accent);">Personalización</h3>
    <p style="color: var(--premium-text);">Temas ilimitados y APIs dedicadas para tu marca.</p>
  </div>
</div>
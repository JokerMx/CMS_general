<!-- DEBUG: Eliminar después de probar -->
<div style="background: yellow; padding: 10px; text-align: center; font-size: 12px;">
  showModal: <%= typeof showModal !== 'undefined' ? showModal : 'UNDEFINED' %> | 
  user: <%= typeof user !== 'undefined' ? user.username : 'NO USER' %>
</div>
<style>
  @keyframes modalBounceIn {
    0% { opacity: 0; transform: scale(0.6) translateY(-40px); }
    60% { opacity: 1; transform: scale(1.03) translateY(0); }
    80% { transform: scale(0.98) translateY(0); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  
  @keyframes drawCircle {
    to { stroke-dashoffset: 0; }
  }
  
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }
  
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes confetti {
    0% { transform: translateY(0) rotate(0deg); opacity: 1; }
    100% { transform: translateY(-500px) rotate(720deg); opacity: 0; }
  }

  .confetti-piece {
    position: fixed;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    animation: confetti 3s ease-out forwards;
    z-index: 10001;
    pointer-events: none;
  }
</style>

<!-- Contenido de fondo -->
<div style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px;">
  <div style="text-align: center;">
    <h2 style="color: var(--text); font-size: 1.5rem;">
      <% if (typeof loadError !== 'undefined' && loadError) { %>
        ⚠️ Sesión iniciada con datos limitados
      <% } else { %>
        👋 ¡Bienvenido<%= typeof user !== 'undefined' && user ? ', ' + (user.full_name || user.username) : '' %>!
      <% } %>
    </h2>
    <p style="color: var(--text-secondary); margin-top: 10px;">
      Has iniciado sesión correctamente.
    </p>
    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 25px;">
      <a href="/" style="background: var(--gradient); color: white; padding: 12px 25px; border-radius: 50px; text-decoration: none; font-weight: 600;">
        Ir al inicio →
      </a>
      <a href="/profile" style="background: var(--badge-bg); color: var(--text); padding: 12px 25px; border-radius: 50px; text-decoration: none; font-weight: 500; border: 1px solid var(--border);">
        👤 Mi Perfil
      </a>
      <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'owner')) { %>
        <a href="/admin/users" style="background: var(--accent); color: white; padding: 12px 25px; border-radius: 50px; text-decoration: none; font-weight: 600;">
          ⚙️ Panel Admin
        </a>
      <% } %>
    </div>
  </div>
</div>

<!-- Modal de bienvenida -->
<% if (typeof showModal !== 'undefined' && showModal) { %>
<div id="welcome-modal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.75); z-index: 10000; backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center;">
  <div style="display: flex; align-items: center; justify-content: center; height: 100%; padding: 20px; width: 100%;">
    <div id="welcome-modal-content" style="background: var(--card-bg, #ffffff); border-radius: 24px; padding: 50px 40px; max-width: 500px; width: 100%; text-align: center; box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5); position: relative; animation: modalBounceIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
      
      <!-- Icono animado -->
      <div style="margin-bottom: 25px; position: relative;">
        <div style="width: 100px; height: 100px; margin: 0 auto; position: relative;">
          <svg width="100" height="100" viewBox="0 0 100 100" style="position: absolute; top: 0; left: 0;">
            <circle cx="50" cy="50" r="46" fill="none" stroke="#6c5ce7" stroke-width="3.5" 
                    stroke-dasharray="289" stroke-dashoffset="289" 
                    style="animation: drawCircle 0.6s ease forwards 0.2s;"/>
          </svg>
          <svg width="100" height="100" viewBox="0 0 100 100" style="position: absolute; top: 0; left: 0;">
            <polyline points="28,52 44,68 72,36" fill="none" stroke="#00b894" stroke-width="5" 
                      stroke-linecap="round" stroke-linejoin="round"
                      stroke-dasharray="120" stroke-dashoffset="120"
                      style="animation: drawCheck 0.5s ease forwards 0.6s;"/>
          </svg>
        </div>
      </div>
      
      <!-- Emoji -->
      <div style="font-size: 3rem; margin-bottom: 15px; animation: fadeInUp 0.5s ease forwards 0.3s; opacity: 0;">
        👋
      </div>
      
      <!-- Título -->
      <h2 style="color: var(--text, #2d3436); font-size: 2rem; margin-bottom: 8px; font-weight: 800; animation: fadeInUp 0.5s ease forwards 0.4s; opacity: 0;">
        ¡Bienvenido de vuelta!
      </h2>
      
      <!-- Nombre -->
      <p style="color: var(--accent, #6c5ce7); font-size: 1.3rem; font-weight: 700; margin-bottom: 15px; animation: fadeInUp 0.5s ease forwards 0.5s; opacity: 0;">
        <%= typeof user !== 'undefined' && user ? (user.full_name || user.username) : 'Usuario' %>
      </p>
      
      <!-- Plan -->
      <div style="background: var(--badge-bg, #f1f2f6); border-radius: 12px; padding: 14px 18px; margin-bottom: 25px; animation: fadeInUp 0.5s ease forwards 0.6s; opacity: 0;">
        <span style="color: var(--text-secondary, #636e72); font-size: 0.9rem;">
          Tu plan actual: 
          <strong style="color: var(--accent, #6c5ce7); text-transform: capitalize;">
            <%= typeof user !== 'undefined' && user ? (user.plan || 'free') : 'free' %>
          </strong>
        </span>
      </div>
      
      <!-- Mensaje -->
      <p style="color: var(--text-secondary, #636e72); font-size: 0.95rem; line-height: 1.6; margin-bottom: 25px; animation: fadeInUp 0.5s ease forwards 0.7s; opacity: 0;">
        <% if (typeof loadError !== 'undefined' && loadError) { %>
          ⚠️ La conexión con la base de datos es inestable. Algunas funciones pueden estar limitadas.
        <% } else { %>
          Estás listo para gestionar tu portafolio de proyectos.
        <% } %>
      </p>
      
      <!-- Botones -->
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; animation: fadeInUp 0.5s ease forwards 0.9s; opacity: 0;">
        <a href="/admin" style="background: var(--gradient, linear-gradient(135deg, #6c5ce7, #a29bfe)); color: #ffffff; padding: 14px 28px; border-radius: 50px; text-decoration: none; font-weight: 700; font-size: 1rem; transition: all 0.3s; box-shadow: 0 5px 20px rgba(108, 92, 231, 0.3); display: inline-block;"
           onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 12px 35px rgba(108, 92, 231, 0.4)'"
           onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 5px 20px rgba(108, 92, 231, 0.3)'">
          ⚙️ Ir al Panel
        </a>
        <a href="/" style="background: var(--badge-bg, #f1f2f6); color: var(--text, #2d3436); padding: 14px 28px; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: all 0.3s; border: 2px solid var(--border, #dfe6e9); display: inline-block;"
           onmouseover="this.style.transform='translateY(-3px)'; this.style.background='var(--border, #dfe6e9)'"
           onmouseout="this.style.transform='translateY(0)'; this.style.background='var(--badge-bg, #f1f2f6)'">
          🏠 Ver Portafolio
        </a>
      </div>
      
      <!-- Cerrar manualmente -->
      <button onclick="closeWelcomeModal()" style="background: none; border: none; color: var(--text-secondary, #b2bec3); font-size: 0.8rem; margin-top: 20px; cursor: pointer; text-decoration: underline; animation: fadeInUp 0.5s ease forwards 1.1s; opacity: 0;">
        Cerrar y continuar
      </button>
    </div>
  </div>
</div>

<!-- Confetti -->
<div id="confetti-container"></div>

<script>
  // Cerrar modal manualmente
  function closeWelcomeModal() {
    const modal = document.getElementById('welcome-modal');
    if (modal) {
      modal.style.opacity = '0';
      modal.style.transition = 'opacity 0.3s ease';
      setTimeout(() => { modal.style.display = 'none'; }, 300);
    }
  }
  
  // Crear confetti
  function createConfetti() {
    const colors = ['#6c5ce7', '#a29bfe', '#00b894', '#ffd700', '#ff6b6b', '#74b9ff', '#fd79a8', '#fdcb6e'];
    const container = document.getElementById('confetti-container');
    if (!container) return;
    
    for (let i = 0; i < 60; i++) {
      setTimeout(() => {
        const piece = document.createElement('div');
        piece.className = 'confetti-piece';
        piece.style.left = Math.random() * 100 + '%';
        piece.style.bottom = '-10px';
        piece.style.background = colors[Math.floor(Math.random() * colors.length)];
        piece.style.width = (Math.random() * 8 + 6) + 'px';
        piece.style.height = (Math.random() * 8 + 6) + 'px';
        piece.style.animationDuration = (Math.random() * 2 + 2) + 's';
        piece.style.animationDelay = Math.random() * 0.5 + 's';
        container.appendChild(piece);
        setTimeout(() => piece.remove(), 3000);
      }, i * 30);
    }
  }
  
  // Auto-redirigir después de 8 segundos
  function startAutoRedirect() {
    setTimeout(() => {
      const modal = document.getElementById('welcome-modal');
      if (modal && modal.style.display !== 'none') {
        window.location.href = '<%= typeof returnTo !== "undefined" ? returnTo : "/admin" %>';
      }
    }, 8000);
  }
  
  // Iniciar
  window.addEventListener('DOMContentLoaded', () => {
    createConfetti();
    startAutoRedirect();
  });
</script>
<% } %>
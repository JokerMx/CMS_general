<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<footer style="background: #1a1d28; margin-top: 60px; padding: 40px 20px 20px;">
  <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 25px; padding-bottom: 20px;">
    
    <!-- Marca -->
    <div>
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
        <span style="font-size: 1.2rem;">🚀</span>
        <span style="font-weight: 700; font-size: 1rem; color: #a78bfa;">
          <%= siteSettings.site_name %>
        </span>
      </div>
      <p style="color: #c8cdd5; font-size: 0.85rem; margin: 0;">
        <%= siteSettings.site_description %>
      </p>
    </div>
    
    <!-- Contacto -->
    <div>
      <h4 style="margin: 0 0 10px 0; color: #ffffff; font-size: 0.9rem;">Contacto</h4>
      <p style="color: #c8cdd5; font-size: 0.85rem; margin: 0 0 4px 0;">📧 <%= siteSettings.contact_email %></p>
      <p style="color: #c8cdd5; font-size: 0.85rem; margin: 0 0 4px 0;">📱 <%= siteSettings.contact_phone %></p>
      <p style="color: #c8cdd5; font-size: 0.85rem; margin: 0 0 4px 0;">📍 <%= siteSettings.contact_address %></p>
    </div>
    
    
    <!-- Redes sociales -->
    <div>
      <h4 style="margin: 0 0 10px 0; color: #ffffff; font-size: 0.9rem;">Síguenos</h4>
      <div style="display: flex; gap: 12px; align-items: center;">
        <a href="<%= siteSettings.social_github || '#' %>" target="_blank" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1); color: #ffffff; text-decoration: none; font-size: 1.2rem; transition: all 0.3s;"
           onmouseover="this.style.background='#333'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'" title="GitHub">
          <i class="fab fa-github"></i>
        </a>
        <a href="<%= siteSettings.social_linkedin || '#' %>" target="_blank" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1); color: #ffffff; text-decoration: none; font-size: 1.2rem; transition: all 0.3s;"
           onmouseover="this.style.background='#0a66c2'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'" title="LinkedIn">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href="<%= siteSettings.social_twitter || '#' %>" target="_blank" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1); color: #ffffff; text-decoration: none; font-size: 1.2rem; transition: all 0.3s;"
           onmouseover="this.style.background='#000'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'" title="Twitter / X">
          <i class="fab fa-x-twitter"></i>
        </a>
        <a href="<%= siteSettings.social_instagram || '#' %>" target="_blank" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1); color: #ffffff; text-decoration: none; font-size: 1.2rem; transition: all 0.3s;"
           onmouseover="this.style.background='#e4405f'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'" title="Instagram">
          <i class="fab fa-instagram"></i>
        </a>
        <a href="<%= siteSettings.social_whatsapp || '#' %>" target="_blank" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1); color: #ffffff; text-decoration: none; font-size: 1.2rem; transition: all 0.3s;"
           onmouseover="this.style.background='#25d366'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'" title="WhatsApp">
          <i class="fab fa-whatsapp"></i>
        </a>
      </div>
    </div>
  </div>
  
  <div style="max-width: 1200px; margin: 0 auto; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.15); text-align: center;">
    <p style="color: #9ca0b0; font-size: 0.8rem; margin: 0;">
      &copy; <%= currentYear %> <%= siteSettings.site_name %>. Todos los derechos reservados.
    </p>
  </div>
</footer>
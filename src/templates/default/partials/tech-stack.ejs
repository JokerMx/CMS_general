<section id="tech-stack" style="padding: 80px 20px; max-width: 1200px; margin: 0 auto;">
  <div style="text-align: center; margin-bottom: 60px;">
    <span style="display: inline-block; background: var(--badge-bg); color: var(--accent); padding: 8px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 600; margin-bottom: 15px;">
      TECNOLOGÍAS
    </span>
    <h2 style="font-size: 2.5rem; margin-bottom: 15px;">Nuestro <span style="background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Stack</span></h2>
    <p style="color: var(--text-secondary); max-width: 700px; margin: 0 auto;">
      Tecnologías detectadas automáticamente desde nuestros repositorios de GitHub. 
      Datos reales basados en frecuencia de uso, estrellas y proyectos.
    </p>
  </div>
  
  <!-- Grid de tecnologías -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
    <% if (typeof techStack !== 'undefined' && techStack.length > 0) { %>
      <% techStack.forEach((tech, index) => { %>
        <div class="fade-in" style="animation-delay: <%= (index * 0.08) %>s; background: var(--card-bg); border-radius: 16px; padding: 25px; box-shadow: var(--card-shadow); border: 1px solid var(--border); transition: transform 0.3s, box-shadow 0.3s;"
             onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 40px rgba(0,0,0,0.12)'"
             onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--card-shadow)'">
          
          <!-- Cabecera: icono + nombre + nivel -->
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
            <span style="font-size: 1.8rem;"><%= tech.icon || '💻' %></span>
            <div style="flex: 1;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-weight: 700; color: var(--text); font-size: 1.1rem;"><%= tech.name %></span>
                <!-- Nivel con fondo del color de la tecnología -->
                <span style="background: <%= tech.color %>; color: #fff; padding: 4px 12px; border-radius: 20px; font-weight: 800; font-size: 0.85rem; text-shadow: 0 1px 2px rgba(0,0,0,0.3);">
                  <%= tech.level %>%
                </span>
              </div>
            </div>
          </div>
          
          <!-- Barra de progreso con fondo oscuro para contraste -->
          <div style="background: var(--badge-bg); border-radius: 10px; height: 12px; overflow: hidden; margin-bottom: 15px; border: 1px solid var(--border);">
            <div style="background: <%= tech.color %>; height: 100%; width: <%= tech.level %>%; border-radius: 10px; transition: width 1.5s ease; min-width: 2px; box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 0 8px <%= tech.color %>60;"></div>
          </div>
          
          <!-- Estadísticas con colores oscuros para legibilidad -->
          <div style="display: flex; gap: 15px; font-size: 0.85rem; flex-wrap: wrap;">
            <% if (tech.count) { %>
              <span style="background: var(--badge-bg); color: var(--text); padding: 4px 10px; border-radius: 20px; font-weight: 500;" title="Repositorios que usan esta tecnología">
                📦 <%= tech.count %> repos
              </span>
            <% } %>
            <% if (tech.stars) { %>
              <span style="background: var(--badge-bg); color: var(--text); padding: 4px 10px; border-radius: 20px; font-weight: 500;" title="Estrellas totales">
                ⭐ <%= tech.stars %>
              </span>
            <% } %>
          </div>
          
          <!-- Repositorios relacionados -->
          <% if (tech.repos && tech.repos.length > 0) { %>
            <div style="margin-top: 12px; display: flex; flex-wrap: wrap; gap: 5px;">
              <% tech.repos.slice(0, 3).forEach(repo => { %>
                <span style="background: <%= tech.color %>25; color: var(--text); padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 500; border: 1px solid <%= tech.color %>40;">
                  <%= repo %>
                </span>
              <% }); %>
              <% if (tech.repos.length > 3) { %>
                <span style="background: var(--badge-bg); color: var(--text-secondary); padding: 3px 8px; border-radius: 20px; font-size: 0.7rem;">
                  +<%= tech.repos.length - 3 %>
                </span>
              <% } %>
            </div>
          <% } %>
        </div>
      <% }); %>
    <% } else { %>
      <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--text-secondary);">
        <p>📊 Conecta tu cuenta de GitHub para ver estadísticas reales de tu stack tecnológico.</p>
      </div>
    <% } %>
  </div>
  
  <!-- Leyenda -->
  <div style="text-align: center; margin-top: 40px; padding: 20px; background: var(--card-bg); border-radius: 16px; border: 1px solid var(--border);">
    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 10px;">
      📊 <strong style="color: var(--text);">¿Cómo se calcula el nivel?</strong>
    </p>
    <p style="color: var(--text-secondary); font-size: 0.85rem;">
      40% frecuencia de uso + 40% estrellas obtenidas + 20% cantidad de proyectos
    </p>
    <% if (typeof profile !== 'undefined' && profile && profile.totalRepos > 0) { %>
      <p style="color: var(--accent); font-size: 0.85rem; margin-top: 8px; font-weight: 500;">
        Basado en <%= profile.totalRepos %> repositorios analizados
      </p>
    <% } %>
  </div>
</section>
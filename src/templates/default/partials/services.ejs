<section id="services" style="padding: 80px 20px; max-width: 1200px; margin: 0 auto;">
  <div style="text-align: center; margin-bottom: 60px;">
    <span style="display: inline-block; background: var(--badge-bg); color: var(--accent); padding: 8px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 600; margin-bottom: 15px;">
      NUESTROS SERVICIOS
    </span>
    <h2 style="font-size: 2.5rem; margin-bottom: 15px;">Soluciones <span style="background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">integrales</span></h2>
    <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Cubrimos todo el ciclo de desarrollo de software, desde la idea hasta el despliegue y mantenimiento.</p>
  </div>
  
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
    <% if (typeof services !== 'undefined' && services.length > 0) { %>
      <% services.forEach((service, index) => { %>
        <div class="fade-in" style="animation-delay: <%= (index * 0.1) %>s; background: var(--card-bg); border-radius: 20px; padding: 35px; box-shadow: var(--card-shadow); transition: transform 0.3s, box-shadow 0.3s; border: 1px solid var(--border);"
             onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 50px var(--accent-glow)'"
             onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--card-shadow)'">
          <div style="font-size: 3rem; margin-bottom: 20px;"><%= service.icon %></div>
          <h3 style="font-size: 1.4rem; margin-bottom: 12px; color: var(--text);"><%= service.title %></h3>
          <p style="color: var(--text-secondary); margin-bottom: 20px;"><%= service.description %></p>
          <div style="display: flex; flex-wrap: wrap; gap: 8px;">
            <% if (service.features) { %>
              <% service.features.forEach(feature => { %>
                <span style="background: var(--badge-bg); color: var(--accent); padding: 5px 12px; border-radius: 50px; font-size: 0.8rem; font-weight: 500;"><%= feature %></span>
              <% }); %>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>
</section>
<section id="contact" style="padding: 80px 20px; position: relative; overflow: hidden; background: transparent; display: flex; justify-content: center; align-items: center;">
  
  <!-- Fondo glass que deja ver partículas -->
  <div style="position: absolute; inset: 0; background: var(--bg-secondary); opacity: 0.85; backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px); z-index: 0;"></div>
  
  <!-- Partículas decorativas locales -->
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;">
    <div style="position: absolute; top: -15%; right: -10%; width: 350px; height: 350px; background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%); border-radius: 50%; opacity: 0.5; animation: float 10s ease-in-out infinite;"></div>
    <div style="position: absolute; bottom: -15%; left: -10%; width: 300px; height: 300px; background: radial-gradient(circle, rgba(0, 206, 201, 0.15) 0%, transparent 70%); border-radius: 50%; opacity: 0.45; animation: float 8s ease-in-out infinite; animation-delay: 3s;"></div>
  </div>

  <!-- Contenedor centrado con ancho máximo -->
  <div style="width: 100%; max-width: 700px; margin: 0 auto; position: relative; z-index: 1;">
    
    <!-- Encabezado -->
    <div style="text-align: center; margin-bottom: 40px;">
      <span style="display: inline-block; background: var(--badge-bg); color: var(--accent); padding: 8px 20px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; margin-bottom: 12px; border: 1px solid var(--border);">
        CONTACTO
      </span>
      <h2 style="font-size: 2.2rem; margin-bottom: 12px; color: var(--text);">
        Hablemos de tu <span style="background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">proyecto</span>
      </h2>
      <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.5;">
        Cuéntanos sobre tu idea y te responderemos en menos de 24 horas.
      </p>
    </div>

    <!-- Tarjeta del formulario -->
    <div style="background: var(--card-bg); border-radius: 20px; padding: 35px; box-shadow: var(--card-shadow); border: 1px solid var(--border);">
      
      <form id="contact-form" style="display: flex; flex-direction: column; gap: 18px;">
        
        <!-- Nombre -->
        <div>
          <label style="display: block; margin-bottom: 5px; font-weight: 600; color: var(--text); font-size: 0.85rem;">
            Nombre <span style="color: #ff6b6b;">*</span>
          </label>
          <input 
            type="text" name="name" required 
            placeholder="Tu nombre completo"
            style="width: 100%; padding: 13px 16px; border-radius: 10px; border: 2px solid var(--border); background: var(--input-bg); color: var(--text); font-size: 0.9rem; transition: all 0.3s; outline: none;"
            onfocus="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 0 0 3px var(--accent-glow)'"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'"
          >
        </div>
        
        <!-- Email -->
        <div>
          <label style="display: block; margin-bottom: 5px; font-weight: 600; color: var(--text); font-size: 0.85rem;">
            Email <span style="color: #ff6b6b;">*</span>
          </label>
          <input 
            type="email" name="email" required 
            placeholder="tu@email.com"
            style="width: 100%; padding: 13px 16px; border-radius: 10px; border: 2px solid var(--border); background: var(--input-bg); color: var(--text); font-size: 0.9rem; transition: all 0.3s; outline: none;"
            onfocus="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 0 0 3px var(--accent-glow)'"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'"
          >
        </div>
        
        <!-- Asunto -->
        <div>
          <label style="display: block; margin-bottom: 5px; font-weight: 600; color: var(--text); font-size: 0.85rem;">
            Asunto
          </label>
          <input 
            type="text" name="subject" 
            placeholder="¿Sobre qué quieres hablar?"
            style="width: 100%; padding: 13px 16px; border-radius: 10px; border: 2px solid var(--border); background: var(--input-bg); color: var(--text); font-size: 0.9rem; transition: all 0.3s; outline: none;"
            onfocus="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 0 0 3px var(--accent-glow)'"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'"
          >
        </div>
        
        <!-- Mensaje -->
        <div>
          <label style="display: block; margin-bottom: 5px; font-weight: 600; color: var(--text); font-size: 0.85rem;">
            Mensaje <span style="color: #ff6b6b;">*</span>
          </label>
          <textarea 
            name="message" rows="4" required 
            placeholder="Cuéntanos sobre tu proyecto..."
            style="width: 100%; padding: 13px 16px; border-radius: 10px; border: 2px solid var(--border); background: var(--input-bg); color: var(--text); font-size: 0.9rem; resize: vertical; min-height: 100px; transition: all 0.3s; outline: none; font-family: inherit;"
            onfocus="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 0 0 3px var(--accent-glow)'"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'"
          ></textarea>
        </div>
        
        <!-- Botón -->
        <button 
          type="submit" 
          style="background: var(--gradient); color: white; padding: 14px 28px; border: none; border-radius: 50px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3); letter-spacing: 0.3px;"
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 25px rgba(108, 92, 231, 0.4)'"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(108, 92, 231, 0.3)'"
        >
          🚀 Enviar Mensaje
        </button>
      </form>
      
      <!-- Mensaje de estado -->
      <div id="form-message" style="margin-top: 15px; display: none;"></div>
      
      <!-- Info de contacto -->
      <div style="margin-top: 25px; padding-top: 18px; border-top: 1px solid var(--border); display: flex; gap: 15px; flex-wrap: wrap; justify-content: center; color: var(--text-secondary); font-size: 0.8rem;">
        <span>📧 hello@devcraftstudio.dev</span>
        <span>📱 +1 (555) 123-4567</span>
        <span>📍 San Francisco, CA</span>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('contact-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);
    
    const btn = e.target.querySelector('button[type="submit"]');
    const originalText = btn.textContent;
    btn.textContent = '⏳ Enviando...';
    btn.disabled = true;
    btn.style.opacity = '0.7';
    
    try {
      const response = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      const result = await response.json();
      const messageEl = document.getElementById('form-message');
      
      if (result.success) {
        messageEl.style.display = 'block';
        messageEl.style.background = '#00b894';
        messageEl.style.color = 'white';
        messageEl.style.padding = '14px 18px';
        messageEl.style.borderRadius = '10px';
        messageEl.style.fontWeight = '500';
        messageEl.style.textAlign = 'center';
        messageEl.style.fontSize = '0.9rem';
        messageEl.innerHTML = '✅ ¡Mensaje enviado con éxito! Te contactaremos pronto.';
        e.target.reset();
      } else {
        throw new Error(result.error || 'Error desconocido');
      }
    } catch (error) {
      const messageEl = document.getElementById('form-message');
      messageEl.style.display = 'block';
      messageEl.style.background = '#ff6b6b';
      messageEl.style.color = 'white';
      messageEl.style.padding = '14px 18px';
      messageEl.style.borderRadius = '10px';
      messageEl.style.fontWeight = '500';
      messageEl.style.textAlign = 'center';
      messageEl.style.fontSize = '0.9rem';
      messageEl.textContent = '❌ Error al enviar. Por favor, intenta de nuevo.';
    } finally {
      btn.textContent = originalText;
      btn.disabled = false;
      btn.style.opacity = '1';
    }
  });
</script>
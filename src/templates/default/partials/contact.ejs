<section id="contact" style="padding: 80px 20px; background: var(--bg-secondary);">
  <div style="max-width: 600px; margin: 0 auto; text-align: center;">
    <span style="display: inline-block; background: var(--badge-bg); color: var(--accent); padding: 8px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 600; margin-bottom: 15px;">
      CONTACTO
    </span>
    <h2 style="font-size: 2.5rem; margin-bottom: 15px;">Hablemos de tu <span style="background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">proyecto</span></h2>
    <p style="color: var(--text-secondary); margin-bottom: 40px;">Cuéntanos sobre tu idea y te responderemos en menos de 24 horas.</p>
    
    <form id="contact-form" style="display: flex; flex-direction: column; gap: 20px; text-align: left;">
      <div>
        <label style="display: block; margin-bottom: 8px; font-weight: 500; color: var(--text);">Nombre</label>
        <input type="text" name="name" required style="width: 100%; padding: 12px 16px; border-radius: 10px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text); font-size: 1rem; transition: border-color 0.2s;" placeholder="Tu nombre completo">
      </div>
      <div>
        <label style="display: block; margin-bottom: 8px; font-weight: 500; color: var(--text);">Email</label>
        <input type="email" name="email" required style="width: 100%; padding: 12px 16px; border-radius: 10px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text); font-size: 1rem;" placeholder="tu@email.com">
      </div>
      <div>
        <label style="display: block; margin-bottom: 8px; font-weight: 500; color: var(--text);">Mensaje</label>
        <textarea name="message" rows="5" required style="width: 100%; padding: 12px 16px; border-radius: 10px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text); font-size: 1rem; resize: vertical;" placeholder="Cuéntanos sobre tu proyecto..."></textarea>
      </div>
      <button type="submit" style="background: var(--gradient); color: white; padding: 15px 30px; border: none; border-radius: 50px; font-size: 1.1rem; font-weight: 700; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; animation: glow 2s infinite;"
              onmouseover="this.style.transform='scale(1.05)'"
              onmouseout="this.style.transform='scale(1)'">
        Enviar Mensaje 🚀
      </button>
    </form>
    
    <div id="form-message" style="margin-top: 20px; display: none;"></div>
  </div>
</section>

<script>
  document.getElementById('contact-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);
    
    try {
      const response = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      const result = await response.json();
      const messageEl = document.getElementById('form-message');
      
      if (result.success) {
        messageEl.style.display = 'block';
        messageEl.style.background = '#00b894';
        messageEl.style.color = 'white';
        messageEl.style.padding = '15px';
        messageEl.style.borderRadius = '10px';
        messageEl.textContent = '✅ ¡Mensaje enviado! Te contactaremos pronto.';
        e.target.reset();
      }
    } catch (error) {
      const messageEl = document.getElementById('form-message');
      messageEl.style.display = 'block';
      messageEl.style.background = '#d63031';
      messageEl.style.color = 'white';
      messageEl.style.padding = '15px';
      messageEl.style.borderRadius = '10px';
      messageEl.textContent = '❌ Error al enviar. Intenta de nuevo.';
    }
  });
</script>
<section id="hero" style="position: relative; z-index: 1; padding: 100px 20px; text-align: center; overflow: hidden; min-height: 80vh; display: flex; align-items: center; justify-content: center; background: transparent;">
  
  <!-- Overlay muy sutil solo para mejorar legibilidad del texto -->
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: var(--bg); opacity: 0.55; z-index: -1;"></div>
  
  <!-- Partículas decorativas estáticas -->
  <div style="position: absolute; top: 15%; left: 8%; width: 280px; height: 280px; background: rgba(108, 92, 231, 0.08); border-radius: 50%; filter: blur(60px); animation: float 6s ease-in-out infinite;"></div>
  <div style="position: absolute; bottom: 12%; right: 6%; width: 220px; height: 220px; background: rgba(108, 92, 231, 0.06); border-radius: 50%; filter: blur(60px); animation: float 8s ease-in-out infinite; animation-delay: 2s;"></div>
  
  <!-- Contenido del hero -->
  <div style="max-width: 850px; margin: 0 auto; position: relative; z-index: 2;">
    
    <!-- Badge superior -->
    <span class="fade-in fade-in-delay-1" style="display: inline-block; background: rgba(108, 92, 231, 0.15); backdrop-filter: blur(10px); color: var(--text); padding: 10px 24px; border-radius: 50px; font-size: 0.95rem; margin-bottom: 25px; border: 1px solid rgba(108, 92, 231, 0.25); letter-spacing: 0.3px; font-weight: 600;">
      🚀 Desarrollo de Software Profesional
    </span>
    
    <!-- Título principal -->
    <h1 class="fade-in fade-in-delay-2" style="font-size: clamp(2.2rem, 5vw, 3.8rem); color: var(--text); margin-bottom: 20px; line-height: 1.15; font-weight: 800; letter-spacing: -0.5px;">
      Creamos el software<br>que <span style="background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">impulsa</span> tu negocio
    </h1>
    
    <!-- Descripción -->
    <p class="fade-in fade-in-delay-3" style="font-size: clamp(1rem, 1.8vw, 1.25rem); color: var(--text-secondary); margin-bottom: 45px; max-width: 650px; margin-left: auto; margin-right: auto; line-height: 1.7;">
      Transformamos tus ideas en aplicaciones robustas y escalables con las últimas tecnologías del mercado.
    </p>
    
    <!-- Botones de acción -->
    <div class="fade-in fade-in-delay-4" style="display: flex; gap: 18px; justify-content: center; flex-wrap: wrap; margin-bottom: 50px;">
      <a href="#contact" style="background: var(--gradient); color: white; padding: 15px 35px; border-radius: 50px; text-decoration: none; font-weight: 700; font-size: 1.05rem; transition: all 0.3s; box-shadow: 0 5px 20px rgba(0,0,0,0.15); display: inline-flex; align-items: center; gap: 8px;"
         onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 15px 40px rgba(0,0,0,0.25)'"
         onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 5px 20px rgba(0,0,0,0.15)'">
        <span>📩</span> Solicitar Cotización
      </a>
      <a href="#portfolio" style="border: 2px solid var(--accent); color: var(--accent); padding: 15px 35px; border-radius: 50px; text-decoration: none; font-weight: 700; font-size: 1.05rem; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px;"
         onmouseover="this.style.transform='translateY(-3px)'; this.style.background='var(--accent)'; this.style.color='white'; this.style.borderColor='var(--accent)'"
         onmouseout="this.style.transform='translateY(0)'; this.style.background='transparent'; this.style.color='var(--accent)'; this.style.borderColor='var(--accent)'">
        <span>💼</span> Ver Proyectos
      </a>
    </div>
    
    <!-- Estadísticas -->
    <% if (typeof profile !== 'undefined' && profile) { %>
    <div class="fade-in fade-in-delay-5" style="display: flex; gap: 25px; justify-content: center; flex-wrap: wrap;">
      
      <div style="background: var(--card-bg); backdrop-filter: blur(15px); border-radius: 18px; padding: 22px 28px; border: 1px solid var(--border); min-width: 130px; transition: transform 0.3s; box-shadow: var(--card-shadow);"
           onmouseover="this.style.transform='translateY(-5px)'"
           onmouseout="this.style.transform='translateY(0)'">
        <div style="font-size: 2.2rem; font-weight: 800; color: var(--accent); line-height: 1;">
          <%= profile.totalRepos || 0 %>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.85rem; margin-top: 5px; font-weight: 500;">
          📦 Repositorios
        </div>
      </div>
      
      <div style="background: var(--card-bg); backdrop-filter: blur(15px); border-radius: 18px; padding: 22px 28px; border: 1px solid var(--border); min-width: 130px; transition: transform 0.3s; box-shadow: var(--card-shadow);"
           onmouseover="this.style.transform='translateY(-5px)'"
           onmouseout="this.style.transform='translateY(0)'">
        <div style="font-size: 2.2rem; font-weight: 800; color: var(--accent); line-height: 1;">
          <%= profile.totalStars || 0 %>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.85rem; margin-top: 5px; font-weight: 500;">
          ⭐ Estrellas
        </div>
      </div>
      
      <div style="background: var(--card-bg); backdrop-filter: blur(15px); border-radius: 18px; padding: 22px 28px; border: 1px solid var(--border); min-width: 130px; transition: transform 0.3s; box-shadow: var(--card-shadow);"
           onmouseover="this.style.transform='translateY(-5px)'"
           onmouseout="this.style.transform='translateY(0)'">
        <div style="font-size: 2.2rem; font-weight: 800; color: var(--accent); line-height: 1;">
          <%= profile.followers || 0 %>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.85rem; margin-top: 5px; font-weight: 500;">
          👥 Seguidores
        </div>
      </div>
      
    </div>
    <% } %>
    
    <!-- Indicador de scroll -->
    <div class="fade-in fade-in-delay-5" style="margin-top: 50px;">
      <a href="#services" style="color: var(--accent); text-decoration: none; font-size: 2rem; transition: all 0.3s; animation: bounce 2s infinite; display: inline-block;"
         onmouseover="this.style.transform='translateY(5px)'"
         onmouseout="this.style.transform='translateY(0)'">
        ⌄
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-12px); }
    60% { transform: translateY(-6px); }
  }
</style>
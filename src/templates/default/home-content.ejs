<div style="text-align: center; margin-bottom: 40px;">
  <h1 style="font-size: 2.8rem; background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 10px;">
    <%= title %>
  </h1>
  <p style="font-size: 1.2rem; color: var(--text-secondary);">Hola, <strong><%= user.name %></strong>. Nos alegra verte de nuevo.</p>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; margin-top: 40px;">
  <div style="background: var(--card-bg); border-radius: 16px; padding: 30px; box-shadow: 0 10px 30px var(--shadow); transition: transform 0.3s, box-shadow 0.3s; cursor: default;"
       onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 15px 40px rgba(0,0,0,0.12)'"
       onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px var(--shadow)'">
    <div style="font-size: 2rem; margin-bottom: 15px;">🚀</div>
    <h3>Rendimiento</h3>
    <p style="color: var(--text-secondary); margin-top: 10px;">Carga ultrarrápida con nuestro motor adaptativo.</p>
  </div>
  <div style="background: var(--card-bg); border-radius: 16px; padding: 30px; box-shadow: 0 10px 30px var(--shadow); transition: transform 0.3s, box-shadow 0.3s; cursor: default;"
       onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 15px 40px rgba(0,0,0,0.12)'"
       onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px var(--shadow)'">
    <div style="font-size: 2rem; margin-bottom: 15px;">🎨</div>
    <h3>Personalización</h3>
    <p style="color: var(--text-secondary); margin-top: 10px;">Elige entre temas claro, oscuro y premium.</p>
  </div>
  <div style="background: var(--card-bg); border-radius: 16px; padding: 30px; box-shadow: 0 10px 30px var(--shadow); transition: transform 0.3s, box-shadow 0.3s; cursor: default;"
       onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 15px 40px rgba(0,0,0,0.12)'"
       onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px var(--shadow)'">
    <div style="font-size: 2rem; margin-bottom: 15px;">⚡</div>
    <h3>Eficiencia</h3>
    <p style="color: var(--text-secondary); margin-top: 10px;">Código limpio y reutilizable para cada cliente.</p>
  </div>
</div>
<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Desarrollo de Software Profesional. Apps web, móviles, cloud e IA." />
  <title>
    <%= typeof title !=='undefined' ? title : 'DevCraft Studio' %>
  </title>
  <style>
    :root {
      /* Fondos - Ligeramente más oscuros para mejor contraste */
      --bg: #eef0f5;
      --bg-secondary: #f4f5f9;
      --text: #2d3436;
      --text-secondary: #636e72;
      --accent: #6c5ce7;
      --accent2: #a29bfe;
      --accent-glow: rgba(108, 92, 231, 0.3);
      --gradient: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%);
      --gradient-hero: linear-gradient(135deg,
          #e8eaf0 0%,
          #f0e8f8 50%,
          #e8f0f5 100%);
      --card-bg: #ffffff;
      --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      --border: #e0e0e0;
      --nav-bg: rgba(255, 255, 255, 0.9);
      --footer-bg: #2d3436;
      --footer-text: #dfe6e9;
      --badge-bg: #f1f2f6;
      --input-bg: #ffffff;
    }

    .dark-theme {
      --bg: #0f0f1a;
      --bg-secondary: #1a1a2e;
      --text: #e0e0e0;
      --text-secondary: #aaa;
      --accent: #bb86fc;
      --accent2: #03dac5;
      --accent-glow: rgba(187, 134, 252, 0.3);
      --gradient: linear-gradient(135deg, #bb86fc 0%, #03dac5 100%);
      --gradient-hero: linear-gradient(135deg, #1a1a2e 0%, #0f0f1a 100%);
      --card-bg: #1e1e32;
      --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
      --border: #333;
      --nav-bg: rgba(15, 15, 26, 0.9);
      --footer-bg: #0a0a15;
      --footer-text: #aaa;
      --badge-bg: #2d2d44;
      --input-bg: #2d2d44;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family:
        "Segoe UI",
        system-ui,
        -apple-system,
        sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      transition:
        background 0.3s,
        color 0.3s;
      overflow-x: hidden;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    main {
      flex: 1;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes float {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-20px);
      }
    }

    @keyframes glow {

      0%,
      100% {
        box-shadow: 0 0 20px var(--accent-glow);
      }

      50% {
        box-shadow:
          0 0 40px var(--accent-glow),
          0 0 60px var(--accent-glow);
      }
    }

    .fade-in {
      animation: fadeInUp 0.6s ease forwards;
      opacity: 0;
    }

    .fade-in-delay-1 {
      animation-delay: 0.1s;
    }

    .fade-in-delay-2 {
      animation-delay: 0.2s;
    }

    .fade-in-delay-3 {
      animation-delay: 0.3s;
    }

    .fade-in-delay-4 {
      animation-delay: 0.4s;
    }

    .fade-in-delay-5 {
      animation-delay: 0.5s;
    }

    /* Asegurar que el contenido esté sobre las partículas */
    header {
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    main {
      position: relative;
      z-index: 1;
    }

    footer {
      position: relative;
      z-index: 1;
    }

    /* El canvas de partículas debe estar detrás */
    #particleCanvas {
      z-index: 0 !important;
    }

    #portfolio,
    #contact,
    #services {
      position: relative;
      z-index: 1;
    }
  </style>
</head>

<body class="<%= theme === 'dark' ? 'dark-theme' : '' %>">
  <%- await include('partials/particles.ejs') %>
    <%- await include('header.ejs') %>
      <main style="position: relative; z-index: 1; flex: 1;">
        <%- typeof body !=='undefined' ? body : '' %>
      </main>
      <%- await include('footer.ejs') %>

        <!-- Script SPA global -->
        <script>
          // Variable global para sidebar
          let sidebarOpen = false;
        </script>
</body>

</html>
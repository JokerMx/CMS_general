<section style="padding: 40px 20px; max-width: 1100px; margin: 0 auto;">

  <!-- Cabecera -->
  <div style="text-align: center; margin-bottom: 30px;">
    <span
      style="display: inline-block; background: var(--badge-bg); color: var(--accent); padding: 8px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 600; margin-bottom: 10px;">
      ⚙️ PANEL DE ADMINISTRACIÓN
    </span>
    <h1 style="font-size: 2rem; color: var(--text);">Gestionar tu sitio</h1>
  </div>

  <!-- Pestañas -->
  <!-- Pestañas -->
  <div style="display: flex; gap: 8px; margin-bottom: 30px; flex-wrap: wrap; justify-content: center;">
    <button class="tab-btn active" data-tab="projects" onclick="switchTab('projects')"
      style="padding: 12px 24px; border-radius: 12px; border: 2px solid var(--accent); background: var(--accent); color: white; font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 0.9rem;">
      📦 Proyectos
    </button>
    <button class="tab-btn" data-tab="users" onclick="switchTab('users')"
      style="padding: 12px 24px; border-radius: 12px; border: 2px solid var(--border); background: var(--card-bg); color: var(--text); font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 0.9rem;">
      👥 Usuarios
    </button>
    <button class="tab-btn" data-tab="social" onclick="switchTab('social')"
      style="padding: 12px 24px; border-radius: 12px; border: 2px solid var(--border); background: var(--card-bg); color: var(--text); font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 0.9rem;">
      🌐 Redes Sociales
    </button>
  </div>

  <!-- TAB: Proyectos -->
  <div id="tab-projects" class="tab-content" style="display: block;">

    <!-- Info del plan -->
    <div
      style="background: var(--card-bg); border-radius: 16px; padding: 20px 25px; margin-bottom: 20px; border: 2px solid <%= userPlan.color %>; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; box-shadow: var(--card-shadow);">
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="font-size: 2rem;">
          <%= userPlan.icon %>
        </span>
        <div>
          <strong style="color: var(--text);">Plan <%= userPlan.name %></strong>
          <span style="color: var(--text-secondary); font-size: 0.9rem; display: block;">
            Máximo: <%= userPlan.maxProjects===Infinity ? '∞' : userPlan.maxProjects %> proyectos
          </span>
        </div>
      </div>
      <a href="/plans"
        style="background: var(--gradient); color: white; padding: 8px 18px; border-radius: 20px; text-decoration: none; font-weight: 600; font-size: 0.85rem;">Cambiar
        Plan</a>
    </div>

    <!-- Contador -->
    <div id="selection-counter"
      style="background: var(--card-bg); border-radius: 12px; padding: 12px 20px; margin-bottom: 20px; text-align: center; border: 1px solid var(--border);">
      <span style="color: var(--text-secondary);">
        Seleccionados: <strong id="selected-count" style="color: var(--accent); font-size: 1.2rem;">0</strong> / <span
          id="max-count">
          <%= userPlan.maxProjects===Infinity ? '∞' : userPlan.maxProjects %>
        </span>
      </span>
      <div id="limit-warning"
        style="display: none; color: #d63031; margin-top: 5px; font-weight: 600; font-size: 0.85rem;"></div>
    </div>

    <!-- Grid de proyectos -->
    <div id="projects-admin-grid"
      style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px; margin-bottom: 20px;">
      <% if (typeof allProjects !=='undefined' && allProjects.length> 0) { %>
        <% allProjects.forEach((project)=> { %>
          <div class="project-admin-card" data-project-name="<%= project.name %>"
            style="background: var(--card-bg); border-radius: 14px; padding: 20px; border: 2px solid var(--border); cursor: pointer; transition: all 0.3s; position: relative;">
            <div class="check-indicator"
              style="position: absolute; top: 12px; right: 12px; width: 28px; height: 28px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; transition: all 0.3s; background: var(--card-bg);">
              <svg class="check-mark" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white"
                stroke-width="3" style="display: none;">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px; padding-right: 35px;">
              <span>
                <%= project.isPrivate ? '🔒' : '📁' %>
              </span>
              <strong style="color: var(--text);">
                <%= project.name %>
              </strong>
            </div>
            <p style="color: var(--text-secondary); font-size: 0.8rem; margin-bottom: 8px;">
              <%= (project.description || '' ).substring(0, 80) %>
            </p>
            <span style="font-size: 0.75rem; color: var(--text-secondary);">⭐ <%= project.stars || 0 %> · <%=
                  project.language || 'N/A' %></span>
          </div>
          <% }); %>
            <% } %>
    </div>

    <!-- Botones -->
    <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
      <button id="btn-save"
        style="background: var(--gradient); color: white; padding: 12px 28px; border-radius: 50px; border: none; font-weight: 700; cursor: pointer; transition: all 0.3s;">💾
        Guardar Selección</button>
      <button id="btn-select-all"
        style="background: var(--card-bg); color: var(--text); padding: 12px 28px; border-radius: 50px; border: 2px solid var(--border); font-weight: 600; cursor: pointer; transition: all 0.3s;">✅
        Todos</button>
      <button id="btn-clear"
        style="background: var(--card-bg); color: var(--text); padding: 12px 28px; border-radius: 50px; border: 2px solid var(--border); font-weight: 600; cursor: pointer; transition: all 0.3s;">❌
        Limpiar</button>
    </div>
  </div>

  <!-- TAB: Usuarios -->
  <div id="tab-users" class="tab-content" style="display: none;">
    <div id="users-content" style="text-align: center; padding: 30px;">
      <p style="color: var(--text-secondary);">Cargando usuarios...</p>
    </div>
  </div>

  <!-- TAB: Redes Sociales -->
  <div id="tab-social" class="tab-content" style="display: none;">
    <div
      style="background: var(--card-bg); border-radius: 16px; padding: 25px; box-shadow: var(--card-shadow); border: 1px solid var(--border); max-width: 500px; margin: 0 auto;">
      <h3 style="color: var(--text); margin-bottom: 20px; text-align: center;">🌐 Configurar Redes Sociales</h3>
      <form id="social-form" style="display: flex; flex-direction: column; gap: 12px;">
        <div>
          <label
            style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--text); font-size: 0.85rem;">🐙
            GitHub</label>
          <input type="url" name="social_github"
            value="<%= (typeof siteSettings !== 'undefined' && siteSettings.social_github) || '' %>"
            placeholder="https://github.com/tuusuario"
            style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text);">
        </div>
        <div>
          <label
            style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--text); font-size: 0.85rem;">💼
            LinkedIn</label>
          <input type="url" name="social_linkedin"
            value="<%= (typeof siteSettings !== 'undefined' && siteSettings.social_linkedin) || '' %>"
            placeholder="https://linkedin.com/company/..."
            style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text);">
        </div>
        <div>
          <label
            style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--text); font-size: 0.85rem;">🐤
            Twitter / X</label>
          <input type="url" name="social_twitter"
            value="<%= (typeof siteSettings !== 'undefined' && siteSettings.social_twitter) || '' %>"
            placeholder="https://twitter.com/..."
            style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text);">
        </div>
        <div>
          <label
            style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--text); font-size: 0.85rem;">📷
            Instagram</label>
          <input type="url" name="social_instagram"
            value="<%= (typeof siteSettings !== 'undefined' && siteSettings.social_instagram) || '' %>"
            placeholder="https://instagram.com/..."
            style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text);">
        </div>
        <div>
          <label
            style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--text); font-size: 0.85rem;">💚
            WhatsApp</label>
          <input type="url" name="social_whatsapp"
            value="<%= (typeof siteSettings !== 'undefined' && siteSettings.social_whatsapp) || '' %>"
            placeholder="https://wa.me/56912345678"
            style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text);">
        </div>
        <button type="submit"
          style="background: var(--gradient); color: white; padding: 12px; border-radius: 10px; border: none; font-weight: 700; cursor: pointer; margin-top: 10px;">💾
          Guardar Redes Sociales</button>
      </form>
      <div id="social-message" style="margin-top: 12px; text-align: center; display: none;"></div>
    </div>
  </div>

</section>

<!-- Modal de éxito -->
<div id="success-modal"
  style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); z-index: 99999; align-items: center; justify-content: center;">
  <div
    style="background: var(--card-bg); border-radius: 20px; padding: 40px; max-width: 400px; width: 90%; text-align: center;">
    <div style="font-size: 3rem; margin-bottom: 15px;">✅</div>
    <h3 style="color: var(--text); margin-bottom: 10px;">¡Guardado!</h3>
    <p style="color: var(--text-secondary); margin-bottom: 20px;" id="success-message"></p>
    <button onclick="document.getElementById('success-modal').style.display='none'"
      style="background: var(--gradient); color: white; padding: 10px 25px; border-radius: 50px; border: none; font-weight: 600; cursor: pointer;">Cerrar</button>
  </div>
</div>
<style>
  @keyframes spin { to { transform: rotate(360deg); } }
  .project-admin-card:hover { border-color: var(--accent) !important; transform: translateY(-3px); }
  .project-admin-card.selected { border-color: #00b894 !important; background: rgba(0,184,148,0.05) !important; }
  .project-admin-card.selected .check-indicator { background: #00b894 !important; border-color: #00b894 !important; }
  .project-admin-card.selected .check-mark { display: block !important; }
  .project-admin-card.disabled { opacity: 0.4; pointer-events: none; }
  .tab-btn.active { background: var(--accent) !important; color: white !important; border-color: var(--accent) !important; }
</style>

<script>
var usersLoaded = false;
var maxProjects = <%= userPlan.maxProjects === Infinity ? 999 : userPlan.maxProjects %>;
var selectedProjects = <%- JSON.stringify(selectedProjects || []) %>;

function switchTab(tabName) {
  document.querySelectorAll('.tab-content').forEach(function(t) { t.style.display = 'none'; });
  document.querySelectorAll('.tab-btn').forEach(function(b) {
    b.classList.remove('active');
    b.style.background = 'var(--card-bg)';
    b.style.color = 'var(--text)';
    b.style.borderColor = 'var(--border)';
  });
  var tabContent = document.getElementById('tab-' + tabName);
  if (tabContent) tabContent.style.display = 'block';
  var activeBtn = document.querySelector('[data-tab="' + tabName + '"]');
  if (activeBtn) {
    activeBtn.classList.add('active');
    activeBtn.style.background = 'var(--accent)';
    activeBtn.style.color = 'white';
    activeBtn.style.borderColor = 'var(--accent)';
  }
  if (tabName === 'users' && !usersLoaded) { loadUsers(); usersLoaded = true; }
}

// PROYECTOS
function updateCounter() {
  var el = document.getElementById('selected-count');
  if (el) el.textContent = selectedProjects.length;
}
function updateDisabled() {
  document.querySelectorAll('.project-admin-card').forEach(function(card) {
    if (!card.classList.contains('selected') && selectedProjects.length >= maxProjects && maxProjects !== 999) {
      card.classList.add('disabled');
    } else { card.classList.remove('disabled'); }
  });
}

document.querySelectorAll('.project-admin-card').forEach(function(card) {
  var name = card.getAttribute('data-project-name');
  if (selectedProjects.indexOf(name) !== -1) card.classList.add('selected');
  card.onclick = function() {
    if (this.classList.contains('selected')) {
      this.classList.remove('selected');
      selectedProjects = selectedProjects.filter(function(p) { return p !== name; });
    } else {
      if (selectedProjects.length >= maxProjects && maxProjects !== 999) {
        var warn = document.getElementById('limit-warning');
        if (warn) { warn.textContent = '⚠️ Límite de ' + maxProjects + ' proyectos'; warn.style.display = 'block';
        setTimeout(function() { warn.style.display = 'none'; }, 3000); }
        return;
      }
      this.classList.add('selected');
      selectedProjects.push(name);
    }
    updateCounter(); updateDisabled();
  };
});
updateCounter(); updateDisabled();

document.getElementById('btn-save').onclick = async function() {
  this.disabled = true; this.textContent = '⏳ Guardando...';
  try {
    var res = await fetch('/api/projects/selection', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ projects: selectedProjects }) });
    var data = await res.json();
    document.getElementById('success-message').textContent = data.message;
    document.getElementById('success-modal').style.display = 'flex';
  } catch(e) { alert('Error'); }
  this.disabled = false; this.textContent = '💾 Guardar Selección';
};

document.getElementById('btn-select-all').onclick = function() {
  document.querySelectorAll('.project-admin-card').forEach(function(card) {
    if (maxProjects !== 999 && selectedProjects.length >= maxProjects) return;
    if (!card.classList.contains('selected')) {
      card.classList.add('selected');
      selectedProjects.push(card.getAttribute('data-project-name'));
    }
  });
  updateCounter(); updateDisabled();
};

document.getElementById('btn-clear').onclick = function() {
  if (confirm('¿Limpiar selección?')) {
    document.querySelectorAll('.project-admin-card').forEach(function(c) { c.classList.remove('selected'); });
    selectedProjects = []; updateCounter(); updateDisabled();
  }
};

// REDES SOCIALES
document.getElementById('social-form').onsubmit = async function(e) {
  e.preventDefault();
  var fd = new FormData(this); var data = {};
  fd.forEach(function(v, k) { data[k] = v; });
  var btn = this.querySelector('button');
  btn.textContent = '⏳ Guardando...'; btn.disabled = true;
  try {
    var res = await fetch('/api/site-settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    var result = await res.json();
    var msg = document.getElementById('social-message');
    if (msg) { msg.style.display = 'block'; msg.style.color = result.success ? '#00b894' : '#d63031'; msg.textContent = result.success ? '✅ Redes guardadas' : '❌ Error';
    setTimeout(function() { msg.style.display = 'none'; }, 3000); }
  } catch(e) { alert('Error'); }
  btn.textContent = '💾 Guardar Redes Sociales'; btn.disabled = false;
};

// USUARIOS
async function loadUsers() {
  var container = document.getElementById('users-content');
  if (!container) return;
  container.innerHTML = '<div style="text-align:center;padding:40px;"><div style="width:30px;height:30px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 10px;"></div><p style="color:var(--text-secondary);">Cargando usuarios...</p></div>';
  try {
    var res = await fetch('/api/admin/users');
    var html = await res.text();
    container.innerHTML = html;
  } catch(e) {
    container.innerHTML = '<p style="color:#d63031;padding:40px;">❌ Error. <a href="/admin/users" style="color:var(--accent);">Ir a Gestión de Usuarios</a></p>';
  }
}

// Modal
document.getElementById('success-modal').onclick = function() { this.style.display = 'none'; };
</script>
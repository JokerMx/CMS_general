<section style="padding: 60px 20px; max-width: 1000px; margin: 0 auto;">
  
  <!-- Cabecera -->
  <div style="text-align: center; margin-bottom: 40px;">
    <span style="display: inline-block; background: var(--badge-bg); color: var(--accent); padding: 8px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 600; margin-bottom: 15px;">
      ⚙️ PANEL DE ADMINISTRACIÓN
    </span>
    <h1 style="font-size: 2.5rem; margin-bottom: 10px; color: var(--text);">Gestionar Proyectos</h1>
    <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;">
      Selecciona los proyectos que quieres mostrar en tu portafolio público.
    </p>
  </div>
  
  <!-- Info del plan -->
  <div style="background: var(--card-bg); border-radius: 16px; padding: 25px 30px; margin-bottom: 30px; border: 2px solid <%= userPlan.color %>; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 15px; box-shadow: var(--card-shadow);">
    <div style="display: flex; align-items: center; gap: 15px;">
      <span style="font-size: 2.5rem;"><%= userPlan.icon %></span>
      <div>
        <h3 style="color: var(--text); margin-bottom: 5px;">Plan <span style="color: <%= userPlan.color %>;"><%= userPlan.name %></span></h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem;">
          <% if (userPlan.maxProjects === Infinity) { %>
            🚀 Proyectos <strong style="color: var(--accent);">ilimitados</strong>
          <% } else { %>
            📦 Máximo <strong style="color: var(--accent);"><%= userPlan.maxProjects %></strong> proyectos
          <% } %>
        </p>
      </div>
    </div>
    <a href="/plans" style="background: var(--gradient); color: white; padding: 10px 20px; border-radius: 25px; text-decoration: none; font-weight: 600; font-size: 0.9rem; white-space: nowrap;">
      Cambiar Plan ↑
    </a>
  </div>
  
  <!-- Contador de seleccionados -->
  <div id="selection-counter" style="background: var(--card-bg); border-radius: 12px; padding: 15px 20px; margin-bottom: 25px; text-align: center; border: 1px solid var(--border); box-shadow: var(--card-shadow);">
    <span style="color: var(--text-secondary); font-size: 1rem;">
      Proyectos seleccionados: 
      <strong id="selected-count" style="color: var(--accent); font-size: 1.3rem;">0</strong> 
      <span style="color: var(--text-secondary);">/</span> 
      <span id="max-count" style="color: var(--text); font-weight: 600;">
        <%= userPlan.maxProjects === Infinity ? '∞' : userPlan.maxProjects %>
      </span>
    </span>
    <div id="limit-warning" style="display: none; color: #d63031; margin-top: 8px; font-weight: 600; font-size: 0.9rem;"></div>
  </div>
  
  <!-- Grid de proyectos -->
  <div id="projects-admin-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-bottom: 30px;">
    <% if (typeof allProjects !== 'undefined' && allProjects.length > 0) { %>
      <% allProjects.forEach((project, index) => { %>
        <div class="project-admin-card" 
             data-project-name="<%= project.name %>"
             style="background: var(--card-bg); border-radius: 16px; padding: 25px; border: 2px solid var(--border); cursor: pointer; transition: all 0.3s; position: relative; opacity: 0; animation: fadeInCard 0.4s ease forwards; animation-delay: <%= index * 0.05 %>s;">
          
          <!-- Checkbox visual -->
          <div class="check-indicator" style="position: absolute; top: 15px; right: 15px; width: 30px; height: 30px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; transition: all 0.3s; background: var(--card-bg); z-index: 2;">
            <svg class="check-mark" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          
          <!-- Contenido -->
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px; padding-right: 35px;">
            <span style="font-size: 1.5rem; flex-shrink: 0;"><%= project.isPrivate ? '🔒' : '📁' %></span>
            <div style="min-width: 0;">
              <h4 style="color: var(--text); font-size: 1.1rem; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= project.name %></h4>
              <span style="font-size: 0.8rem; color: var(--text-secondary);">
                ⭐ <%= project.stars || 0 %> · 🔀 <%= project.forks || 0 %> · <%= project.language || 'N/A' %>
              </span>
            </div>
          </div>
          
          <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.5; margin-bottom: 12px;">
            <%= (project.description || 'Sin descripción').substring(0, 80) %><%= (project.description || '').length > 80 ? '...' : '' %>
          </p>
          
          <!-- Tags -->
          <div style="display: flex; flex-wrap: wrap; gap: 5px;">
            <% if (project.techBadges && project.techBadges.length > 0) { %>
              <% project.techBadges.slice(0, 3).forEach(badge => { %>
                <span style="background: <%= badge.color %>20; color: <%= badge.color %>; padding: 3px 9px; border-radius: 15px; font-size: 0.7rem; font-weight: 500; border: 1px solid <%= badge.color %>30;">
                  <%= badge.name %>
                </span>
              <% }); %>
              <% if (project.techBadges.length > 3) { %>
                <span style="background: var(--badge-bg); color: var(--text-secondary); padding: 3px 9px; border-radius: 15px; font-size: 0.7rem;">+<%= project.techBadges.length - 3 %></span>
              <% } %>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div style="grid-column: 1/-1; text-align: center; padding: 40px;">
        <p style="color: var(--text-secondary);">No se encontraron proyectos.</p>
      </div>
    <% } %>
  </div>
  
  <!-- Botones de acción -->
  <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
    <button id="btn-save" style="background: var(--gradient); color: white; padding: 15px 35px; border-radius: 50px; border: none; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: all 0.3s; position: relative; overflow: hidden;"
            onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 15px 35px var(--accent-glow)'"
            onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
      <span id="btn-save-text">💾 Guardar Selección</span>
      <span id="btn-save-loader" style="display: none; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
        <span style="display: inline-block; width: 20px; height: 20px; border: 3px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.8s linear infinite;"></span>
      </span>
    </button>
    <button id="btn-select-all" style="background: var(--card-bg); color: var(--text); padding: 15px 35px; border-radius: 50px; border: 2px solid var(--border); font-weight: 600; cursor: pointer; transition: all 0.3s;"
            onmouseover="this.style.transform='translateY(-3px)'; this.style.borderColor='var(--accent)'; this.style.boxShadow='0 10px 25px var(--accent-glow)'"
            onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
      ✅ Seleccionar Todos
    </button>
    <button id="btn-clear" style="background: var(--card-bg); color: var(--text); padding: 15px 35px; border-radius: 50px; border: 2px solid var(--border); font-weight: 600; cursor: pointer; transition: all 0.3s;"
            onmouseover="this.style.transform='translateY(-3px)'; this.style.borderColor='#d63031'; this.style.boxShadow='0 10px 25px rgba(214,48,49,0.2)'"
            onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
      ❌ Limpiar Selección
    </button>
    <a href="/" style="background: var(--card-bg); color: var(--text); padding: 15px 35px; border-radius: 50px; border: 2px solid var(--border); text-decoration: none; font-weight: 600; transition: all 0.3s; display: inline-block;"
       onmouseover="this.style.transform='translateY(-3px)'; this.style.borderColor='var(--accent)'; this.style.boxShadow='0 10px 25px var(--accent-glow)'"
       onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
      🏠 Ir al Portafolio
    </a>
  </div>
</section>

<!-- ========================================== -->
<!-- MODAL DE ÉXITO ANIMADO -->
<!-- ========================================== -->
<div id="success-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.75); z-index: 10000; backdrop-filter: blur(8px);">
  <div style="display: flex; align-items: center; justify-content: center; height: 100%; padding: 20px;">
    <div id="success-modal-content" style="background: #ffffff; border-radius: 24px; padding: 50px 40px; max-width: 480px; width: 100%; text-align: center; box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5); position: relative; animation: modalBounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
      
      <button id="btn-close-success" style="position: absolute; top: 15px; right: 15px; background: #f1f2f6; color: #636e72; border: none; width: 36px; height: 36px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center;"
              onmouseover="this.style.background='#d63031'; this.style.color='white'"
              onmouseout="this.style.background='#f1f2f6'; this.style.color='#636e72'">
        ✕
      </button>
      
      <div style="margin-bottom: 25px; position: relative;">
        <div style="width: 90px; height: 90px; margin: 0 auto; position: relative;">
          <svg width="90" height="90" viewBox="0 0 90 90" style="position: absolute; top: 0; left: 0;">
            <circle cx="45" cy="45" r="42" fill="none" stroke="#00b894" stroke-width="3.5" 
                    stroke-dasharray="264" stroke-dashoffset="264" 
                    style="animation: drawCircle 0.6s ease forwards 0.2s;"/>
          </svg>
          <svg width="90" height="90" viewBox="0 0 90 90" style="position: absolute; top: 0; left: 0;">
            <polyline points="25,48 40,62 65,32" fill="none" stroke="#00b894" stroke-width="4.5" 
                      stroke-linecap="round" stroke-linejoin="round"
                      stroke-dasharray="100" stroke-dashoffset="100"
                      style="animation: drawCheck 0.4s ease forwards 0.6s;"/>
          </svg>
        </div>
      </div>
      
      <h2 style="color: #00b894; font-size: 1.8rem; margin-bottom: 10px; font-weight: 800; animation: fadeInUp 0.5s ease forwards 0.3s; opacity: 0;">
        ¡Guardado Exitoso!
      </h2>
      
      <p id="success-message" style="color: #636e72; font-size: 1.05rem; line-height: 1.6; margin-bottom: 10px; animation: fadeInUp 0.5s ease forwards 0.5s; opacity: 0;">
        Tus proyectos han sido guardados correctamente.
      </p>
      
      <div id="success-detail" style="background: #f1f2f6; border-radius: 12px; padding: 16px 20px; margin-bottom: 25px; animation: fadeInUp 0.5s ease forwards 0.7s; opacity: 0;">
        <span style="color: #2d3436; font-weight: 600; font-size: 1rem;">
          <span id="success-count" style="color: #00b894; font-size: 1.8rem; font-weight: 800;">0</span> proyectos seleccionados
        </span>
      </div>
      
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; animation: fadeInUp 0.5s ease forwards 0.9s; opacity: 0;">
        <button id="btn-go-portfolio" style="background: linear-gradient(135deg, #00b894, #00cec9); color: #ffffff; padding: 14px 30px; border-radius: 50px; border: none; font-weight: 700; font-size: 1rem; cursor: pointer; transition: all 0.3s; box-shadow: 0 5px 20px rgba(0, 184, 148, 0.3);"
                onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 12px 35px rgba(0, 184, 148, 0.4)'"
                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 5px 20px rgba(0, 184, 148, 0.3)'">
          🏠 Ver Portafolio
        </button>
        <button id="btn-keep-editing" style="background: #f1f2f6; color: #2d3436; padding: 14px 30px; border-radius: 50px; border: 2px solid #dfe6e9; font-weight: 600; font-size: 1rem; cursor: pointer; transition: all 0.3s;"
                onmouseover="this.style.transform='translateY(-3px)'; this.style.background='#dfe6e9'"
                onmouseout="this.style.transform='translateY(0)'; this.style.background='#f1f2f6'">
          ✏️ Seguir Editando
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes modalBounceIn {
    0% { opacity: 0; transform: scale(0.6) translateY(-40px); }
    60% { opacity: 1; transform: scale(1.03) translateY(0); }
    80% { transform: scale(0.98) translateY(0); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  
  @keyframes drawCircle {
    to { stroke-dashoffset: 0; }
  }
  
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }
  
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes fadeInCard {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0, 184, 148, 0.4); }
    50% { box-shadow: 0 0 0 15px rgba(0, 184, 148, 0); }
  }
  
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-8px); }
    50% { transform: translateX(8px); }
    75% { transform: translateX(-4px); }
  }
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  
  .project-admin-card:hover {
    border-color: var(--accent) !important;
    box-shadow: 0 10px 30px var(--accent-glow) !important;
    transform: translateY(-5px) !important;
  }
  
  .project-admin-card.selected {
    border-color: #00b894 !important;
    background: rgba(0, 184, 148, 0.04) !important;
    box-shadow: 0 5px 25px rgba(0, 184, 148, 0.15) !important;
  }
  
  .project-admin-card.selected .check-indicator {
    background: #00b894 !important;
    border-color: #00b894 !important;
    animation: pulse 2s infinite;
  }
  
  .project-admin-card.selected .check-mark {
    display: block !important;
  }
  
  .project-admin-card.disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
    filter: grayscale(0.6);
  }
</style>

<script>
(function() {
  // Configuración
  const maxProjects = <%= userPlan.maxProjects === Infinity ? 999 : userPlan.maxProjects %>;
  let selectedProjects = <%- JSON.stringify(selectedProjects || []) %>;
  
  // Elementos del DOM
  const btnSave = document.getElementById('btn-save');
  const btnSelectAll = document.getElementById('btn-select-all');
  const btnClear = document.getElementById('btn-clear');
  const btnCloseSuccess = document.getElementById('btn-close-success');
  const btnGoPortfolio = document.getElementById('btn-go-portfolio');
  const btnKeepEditing = document.getElementById('btn-keep-editing');
  const successModal = document.getElementById('success-modal');
  const limitWarning = document.getElementById('limit-warning');
  const selectedCount = document.getElementById('selected-count');
  const selectionCounter = document.getElementById('selection-counter');
  const cards = document.querySelectorAll('.project-admin-card');
  
  // Inicializar
  function init() {
    cards.forEach(function(card) {
      var projectName = card.getAttribute('data-project-name');
      if (selectedProjects.indexOf(projectName) !== -1) {
        card.classList.add('selected');
      }
      card.addEventListener('click', function() {
        toggleProject(card, projectName);
      });
    });
    updateCounter();
    checkLimit();
  }
  
  // Toggle selección
  function toggleProject(card, projectName) {
    if (card.classList.contains('selected')) {
      card.classList.remove('selected');
      selectedProjects = selectedProjects.filter(function(p) { return p !== projectName; });
    } else {
      if (selectedProjects.length >= maxProjects) {
        showWarning('⚠️ Has alcanzado el límite de ' + maxProjects + ' proyectos para tu plan actual.');
        selectionCounter.style.animation = 'shake 0.5s ease';
        setTimeout(function() { selectionCounter.style.animation = ''; }, 500);
        return;
      }
      card.classList.add('selected');
      selectedProjects.push(projectName);
    }
    updateCounter();
    checkLimit();
    hideWarning();
  }
  
  // Seleccionar todos
  function selectAll() {
    var available = maxProjects - selectedProjects.length;
    
    if (available <= 0) {
      showWarning('⚠️ Ya tienes el máximo de ' + maxProjects + ' proyectos seleccionados.');
      return;
    }
    
    var added = 0;
    cards.forEach(function(card, index) {
      if (added >= available) return;
      var name = card.getAttribute('data-project-name');
      if (selectedProjects.indexOf(name) === -1) {
        setTimeout(function() { card.classList.add('selected'); }, index * 50);
        selectedProjects.push(name);
        added++;
      }
    });
    
    setTimeout(function() {
      updateCounter();
      checkLimit();
    }, cards.length * 50 + 100);
  }
  
  // Limpiar selección
  function clearSelection() {
    if (selectedProjects.length === 0) return;
    if (confirm('¿Estás seguro de eliminar los ' + selectedProjects.length + ' proyectos seleccionados?')) {
      cards.forEach(function(card) { card.classList.remove('selected'); });
      selectedProjects = [];
      updateCounter();
      checkLimit();
      hideWarning();
    }
  }
  
  // Guardar selección
  function saveSelection() {
    var btnText = document.getElementById('btn-save-text');
    var btnLoader = document.getElementById('btn-save-loader');
    
    btnText.style.opacity = '0';
    btnLoader.style.display = 'flex';
    btnLoader.style.alignItems = 'center';
    btnLoader.style.justifyContent = 'center';
    btnSave.disabled = true;
    btnSave.style.opacity = '0.8';
    btnSave.style.cursor = 'wait';
    
    fetch('/api/projects/selection', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ projects: selectedProjects })
    })
    .then(function(response) { return response.json(); })
    .then(function(result) {
      if (result.success) {
        showSuccessModal(result.selected ? result.selected.length : selectedProjects.length);
      } else {
        showWarning('⚠️ ' + result.error);
        resetButton();
      }
    })
    .catch(function() {
      showWarning('❌ Error de conexión. Intenta de nuevo.');
      resetButton();
    });
  }
  
  function resetButton() {
    var btnText = document.getElementById('btn-save-text');
    var btnLoader = document.getElementById('btn-save-loader');
    btnText.style.opacity = '1';
    btnLoader.style.display = 'none';
    btnSave.disabled = false;
    btnSave.style.opacity = '1';
    btnSave.style.cursor = 'pointer';
  }
  
  // Modal de éxito
  function showSuccessModal(count) {
    document.getElementById('success-count').textContent = count;
    document.getElementById('success-message').textContent = 
      count === 0 
        ? 'No hay proyectos seleccionados. Puedes volver a editar tu selección.' 
        : 'Tus ' + count + ' proyectos han sido guardados y ya están visibles en tu portafolio público.';
    
    successModal.style.display = 'block';
    document.body.style.overflow = 'hidden';
    
    // Reiniciar animaciones
    var circles = successModal.querySelectorAll('circle');
    var checks = successModal.querySelectorAll('polyline');
    circles.forEach(function(c) {
      c.style.animation = 'none';
      c.offsetHeight;
      c.style.animation = 'drawCircle 0.6s ease forwards 0.2s';
    });
    checks.forEach(function(c) {
      c.style.animation = 'none';
      c.offsetHeight;
      c.style.animation = 'drawCheck 0.4s ease forwards 0.6s';
    });
    
    resetButton();
  }
  
  function closeSuccessModal() {
    successModal.style.display = 'none';
    document.body.style.overflow = 'auto';
  }
  
  function goToPortfolio() {
    window.location.href = '/';
  }
  
  // Contador
  function updateCounter() {
    selectedCount.textContent = selectedProjects.length;
    selectedCount.style.transform = 'scale(1.3)';
    selectedCount.style.transition = 'transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
    setTimeout(function() { selectedCount.style.transform = 'scale(1)'; }, 200);
  }
  
  // Límite
  function checkLimit() {
    var remaining = maxProjects - selectedProjects.length;
    if (remaining <= 0 && maxProjects !== 999) {
      cards.forEach(function(card) {
        if (!card.classList.contains('selected')) card.classList.add('disabled');
      });
    } else {
      cards.forEach(function(card) { card.classList.remove('disabled'); });
    }
  }
  
  // Advertencias
  function showWarning(message) {
    limitWarning.textContent = message;
    limitWarning.style.display = 'block';
    limitWarning.style.animation = 'fadeInUp 0.3s ease';
    setTimeout(function() { limitWarning.style.display = 'none'; }, 4000);
  }
  
  function hideWarning() {
    limitWarning.style.display = 'none';
  }
  
  // Event listeners
  btnSave.addEventListener('click', saveSelection);
  btnSelectAll.addEventListener('click', selectAll);
  btnClear.addEventListener('click', clearSelection);
  btnCloseSuccess.addEventListener('click', closeSuccessModal);
  btnGoPortfolio.addEventListener('click', goToPortfolio);
  btnKeepEditing.addEventListener('click', closeSuccessModal);
  
  // Cerrar modal con Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && successModal.style.display === 'block') {
      closeSuccessModal();
    }
  });
  
  // Cerrar modal haciendo clic fuera
  successModal.addEventListener('click', function(e) {
    if (e.target === successModal) closeSuccessModal();
  });
  
  // Inicializar
  init();
})();
</script>
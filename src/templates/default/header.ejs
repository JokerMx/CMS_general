<header
  style="background: var(--nav-bg); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); position: sticky; top: 0; z-index: 1000; border-bottom: 1px solid var(--border);">
  <nav
    style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 15px 20px;">

    <!-- Logo -->
    <a href="/" data-section="hero"
      style="font-size: 1.6rem; font-weight: 800; text-decoration: none; background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.5px;">
      Devfree<span
        style="background: var(--accent2); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Studio</span>
    </a>

    <!-- Menú desktop -->
    <ul style="display: flex; list-style: none; gap: 25px; align-items: center;">
      <li><a href="/" data-section="hero"
          style="color: var(--text); text-decoration: none; font-weight: 500;">Inicio</a></li>
      <li><a href="/services" data-section="services"
          style="color: var(--text); text-decoration: none; font-weight: 500;">Servicios</a></li>
      <li><a href="/portfolio" data-section="portfolio"
          style="color: var(--text); text-decoration: none; font-weight: 500;">Proyectos</a></li>
      <li><a href="/tech-stack" data-section="tech-stack"
          style="color: var(--text); text-decoration: none; font-weight: 500;">Tecnologías</a></li>
      <li><a href="/contact-page" data-section="contact"
          style="color: var(--text); text-decoration: none; font-weight: 500;">Contacto</a></li>
      <li><a href="/plans" style="color: var(--text); text-decoration: none; font-weight: 500;">Planes</a></li>

      <% if (typeof user !=='undefined' && user) { %>
        <li>
          <a href="/profile"
            style="display: flex; align-items: center; gap: 8px; text-decoration: none; padding: 6px 14px; border-radius: 50px; background: var(--badge-bg); border: 1px solid var(--border);">
            <span
              style="width: 28px; height: 28px; border-radius: 50%; background: var(--gradient); display: flex; align-items: center; justify-content: center; color: white; font-size: 0.75rem; font-weight: 700;">
              <%= (user.full_name || user.username).charAt(0).toUpperCase() %>
            </span>
            <span style="color: var(--text); font-size: 0.85rem; font-weight: 500;">
              <%= user.full_name || user.username %>
            </span>
          </a>
        </li>
        <% if (user.role==='admin' || user.role==='owner' ) { %>
          <li><a href="/admin" style="color: var(--accent); text-decoration: none; font-weight: 600;">Admin</a>
          </li>
          <% } %>
            <li><a href="/logout"
                style="color: var(--text-secondary); text-decoration: none; font-weight: 500;">Salir</a></li>
            <% } else { %>
              <li>
                <a href="/login"
                  style="background: var(--gradient); color: white; padding: 8px 15px; border-radius: 20px; text-decoration: none; font-size: 0.9rem; font-weight: 600;">Iniciar
                  Sesión</a>
              </li>
              <% } %>

                <!-- Botón tema -->
                <li>
                  <a href="/toggle-theme?current=<%= theme %>"
                    style="background: var(--card-bg); padding: 8px 12px; border-radius: 50px; border: 1px solid var(--border); font-size: 1.2rem; text-decoration: none; cursor: pointer; transition: transform 0.2s; display: inline-block;"
                    onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'"
                    title="Cambiar tema claro/oscuro">
                    <%= theme==='dark' ? '☀️' : '🌙' %>
                  </a>
                </li>
    </ul>

    <!-- Botón hamburguesa (móvil) -->
    <button id="menu-toggle" onclick="toggleSidebar()"
      style="display: none; background: var(--card-bg); border: 1px solid var(--border); color: var(--text); width: 40px; height: 40px; border-radius: 10px; font-size: 1.3rem; cursor: pointer; align-items: center; justify-content: center;">
      ☰
    </button>
  </nav>
</header>

<!-- OVERLAY -->
<div id="sidebar-overlay" onclick="closeSidebar()"
  style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1999;">
</div>

<!-- SIDEBAR MÓVIL -->
<aside id="sidebar"
  style="position: fixed; top: 0; right: -300px; width: 280px; height: 100%; background: var(--card-bg); z-index: 2000; transition: right 0.3s ease; box-shadow: -5px 0 30px rgba(0,0,0,0.3); overflow-y: auto; padding: 20px;">

  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
    <span
      style="font-weight: 700; font-size: 1.1rem; background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Menú</span>
    <button onclick="closeSidebar()"
      style="background: none; border: none; color: var(--text); font-size: 1.3rem; cursor: pointer;">✕</button>
  </div>

  <nav>
    <ul style="list-style: none; display: flex; flex-direction: column; gap: 8px;">
      <li><a href="/" data-section="hero" onclick="closeSidebar()"
          style="display: block; padding: 12px 15px; border-radius: 10px; color: var(--text); text-decoration: none; font-weight: 500; transition: background 0.2s;"
          onmouseover="this.style.background='var(--badge-bg)'" onmouseout="this.style.background='transparent'">🏠
          Inicio</a></li>
      <li><a href="/services" data-section="services" onclick="closeSidebar()"
          style="display: block; padding: 12px 15px; border-radius: 10px; color: var(--text); text-decoration: none; font-weight: 500; transition: background 0.2s;"
          onmouseover="this.style.background='var(--badge-bg)'" onmouseout="this.style.background='transparent'">🖥️
          Servicios</a></li>
      <li><a href="/portfolio" data-section="portfolio" onclick="closeSidebar()"
          style="display: block; padding: 12px 15px; border-radius: 10px; color: var(--text); text-decoration: none; font-weight: 500; transition: background 0.2s;"
          onmouseover="this.style.background='var(--badge-bg)'" onmouseout="this.style.background='transparent'">📁
          Proyectos</a></li>
      <li><a href="/tech-stack" data-section="tech-stack" onclick="closeSidebar()"
          style="display: block; padding: 12px 15px; border-radius: 10px; color: var(--text); text-decoration: none; font-weight: 500; transition: background 0.2s;"
          onmouseover="this.style.background='var(--badge-bg)'" onmouseout="this.style.background='transparent'">📊
          Tecnologías</a></li>
      <li><a href="/plans" onclick="closeSidebar()"
          style="display: block; padding: 12px 15px; border-radius: 10px; color: var(--text); text-decoration: none; font-weight: 500; transition: background 0.2s;"
          onmouseover="this.style.background='var(--badge-bg)'" onmouseout="this.style.background='transparent'">💎
          Planes</a></li>
      <li><a href="/contact-page" data-section="contact" onclick="closeSidebar()"
          style="display: block; padding: 12px 15px; border-radius: 10px; color: var(--text); text-decoration: none; font-weight: 500; transition: background 0.2s;"
          onmouseover="this.style.background='var(--badge-bg)'" onmouseout="this.style.background='transparent'">📧
          Contacto</a></li>

      <li style="border-top: 1px solid var(--border); margin: 5px 0;"></li>

      <% if (typeof user !=='undefined' && user) { %>
        <li><a href="/profile" onclick="closeSidebar()"
            style="display: block; padding: 12px 15px; border-radius: 10px; color: var(--text); text-decoration: none; font-weight: 500;">👤
            Mi Perfil</a></li>
        <% if (user.role==='admin' || user.role==='owner' ) { %>
          <li><a href="/admin" style="color: var(--accent); text-decoration: none; font-weight: 600;">Admin</a></li>
          <% } %>
            <li><a href="/logout" onclick="closeSidebar()"
                style="display: block; padding: 12px 15px; border-radius: 10px; color: #ff6b6b; text-decoration: none; font-weight: 500;">🚪
                Salir</a></li>
            <% } else { %>
              <li><a href="/login" onclick="closeSidebar()"
                  style="display: block; text-align: center; background: var(--gradient); color: white; padding: 14px; border-radius: 50px; text-decoration: none; font-weight: 600; margin-top: 10px;">Iniciar
                  Sesión</a></li>
              <% } %>

                <li>
                  <a href="/toggle-theme?current=<%= theme %>" onclick="closeSidebar()"
                    style="display: block; padding: 12px 15px; border-radius: 10px; color: var(--text); text-decoration: none; font-weight: 500; background: var(--badge-bg); text-align: center;">
                    <%= theme==='dark' ? '☀️ Modo Claro' : '🌙 Modo Oscuro' %>
                  </a>
                </li>
    </ul>
  </nav>
</aside>

<style>
  @media (max-width: 860px) {
    header nav ul {
      display: none !important;
    }

    #menu-toggle {
      display: flex !important;
    }
  }

  @media (min-width: 861px) {

    #sidebar,
    #sidebar-overlay {
      display: none !important;
    }
  }

  .sidebar-open {
    overflow: hidden;
  }
</style>

<script>
  function toggleSidebar() {
    document.getElementById('sidebar').style.right = '0';
    document.getElementById('sidebar-overlay').style.display = 'block';
    document.body.classList.add('sidebar-open');
  }

  function closeSidebar() {
    document.getElementById('sidebar').style.right = '-300px';
    document.getElementById('sidebar-overlay').style.display = 'none';
    document.body.classList.remove('sidebar-open');
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeSidebar();
  });
</script>
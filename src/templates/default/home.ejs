<!-- Contenedor principal de la SPA -->
<div id="app-content" style="min-height: 60vh; transition: opacity 0.3s ease;">
  <!-- Carga inicial: Hero -->
  <div id="section-loading" style="text-align: center; padding: 80px 20px; display: none;">
    <div style="width: 40px; height: 40px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 15px;"></div>
    <p style="color: var(--text-secondary);">Cargando...</p>
  </div>
</div>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  
  .section-enter {
    animation: fadeInUp 0.4s ease forwards;
  }
  
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
(function() {
  // Mapeo de secciones
  const sections = {
    'hero': { url: '/api/section/hero', title: 'Inicio' },
    'services': { url: '/api/section/services', title: 'Servicios' },
    'portfolio': { url: '/api/section/portfolio', title: 'Proyectos' },
    'tech-stack': { url: '/api/section/tech-stack', title: 'Tecnologías' },
    'contact': { url: '/api/section/contact', title: 'Contacto' }
  };
  
  let currentSection = null;
  
  // Cargar sección
  async function loadSection(sectionName, pushState = true) {
    const section = sections[sectionName];
    if (!section) return;
    
    const container = document.getElementById('app-content');
    const loading = document.getElementById('section-loading');
    
    // Mostrar loader
    if (loading) loading.style.display = 'block';
    if (container.children.length > 1) {
      Array.from(container.children).forEach(child => {
        if (child.id !== 'section-loading') child.style.opacity = '0.4';
      });
    }
    
    try {
      const response = await fetch(section.url);
      if (!response.ok) throw new Error('Error al cargar');
      
      const html = await response.text();
      
      // Limpiar contenedor (excepto loader)
      container.innerHTML = '';
      container.appendChild(loading);
      
      // Crear wrapper para la nueva sección
      const wrapper = document.createElement('div');
      wrapper.className = 'section-enter';
      wrapper.innerHTML = html;
      container.appendChild(wrapper);
      
      // Ocultar loader
      if (loading) loading.style.display = 'none';
      
      // Actualizar URL
      if (pushState) {
        const url = sectionName === 'hero' ? '/' : `/${sectionName}`;
        history.pushState({ section: sectionName }, section.title, url);
      }
      
      // Actualizar título
      document.title = `${section.title} | DevCraft Studio`;
      
      // Scroll suave al contenido
      wrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
      
      // Reinicializar scripts de la sección (partículas, carrusel, etc.)
      if (sectionName === 'services') {
        setTimeout(() => {
          if (typeof initServices3D === 'function') initServices3D();
        }, 100);
      }
      
      currentSection = sectionName;
      
      // Actualizar menú activo
      updateActiveMenu(sectionName);
      
    } catch (error) {
      console.error('Error cargando sección:', error);
      if (loading) loading.style.display = 'none';
      container.innerHTML += `<p style="text-align:center;padding:40px;color:#ff6b6b;">Error al cargar. <a href="/" style="color:var(--accent);">Recargar</a></p>`;
    }
  }
  
  // Actualizar estilo del menú activo
  function updateActiveMenu(sectionName) {
    document.querySelectorAll('[data-section]').forEach(link => {
      if (link.dataset.section === sectionName) {
        link.style.color = 'var(--accent)';
        link.style.fontWeight = '600';
      } else {
        link.style.color = 'var(--text)';
        link.style.fontWeight = '500';
      }
    });
  }
  
  // Interceptar clics del menú
  document.addEventListener('click', function(e) {
    const link = e.target.closest('[data-section]');
    if (!link) return;
    
    e.preventDefault();
    const section = link.dataset.section;
    if (section && sections[section]) {
      loadSection(section);
      
      // Cerrar sidebar si está abierto
      if (typeof closeSidebar === 'function') closeSidebar();
    }
  });
  
  // Navegación con botones atrás/adelante
  window.addEventListener('popstate', function(e) {
    if (e.state && e.state.section) {
      loadSection(e.state.section, false);
    }
  });
  
  // Carga inicial: detectar URL
  const path = window.location.pathname.replace('/', '');
  if (path && sections[path]) {
    loadSection(path, false);
  } else if (path === '') {
    loadSection('hero', false);
  }
  
  // Scroll al hash si existe
  if (window.location.hash) {
    setTimeout(() => {
      const el = document.querySelector(window.location.hash);
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    }, 500);
  }
})();
</script>